
- Creating a user by specifying its alias
	SHOULD : create the user inside the database 

- Trying to connect as the same user but with a different cookie 
	SHOULD : refuse the connexion and NOT create another user with the same alias

- Creating a tournament that doesnt exist 
	SHOULD : create a tournament 

- Creating a wrong tournament because of
	- Wrong input of maxPlayers (odd number, no number, inferior to 2 or superior to 64, letters..)
	- Wrong name (unauthorized characters, empty input or less than 3 characters...)
	- Tournament already created
	- Creator of the tournament is already inside another tournament
	- Other cases if there are


- Logging as a player already inside a tournament, and trying to join or create another
	SHOULD : print an error accordingly and show the tournaments list

- Creating a tournament with bad credentials  or a duplicate
	SHOULD : print an error accordingly and NOT create the tournament

- Trying to join multiple tournament
	SHOULD : print error and block entrance into another 



I recommend **automated integration tests with Vitest** instead of an ad-hoc script. Here's why and how:

## Best Approach: Vitest + Supertest for API tests

**Setup:**

```bash
npm install -D vitest supertest @types/supertest
```

**Create `server/tests/api.test.ts`:**

````typescript
import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import supertest from 'supertest';
import { getDatabase } from '../src/db/databaseSingleton.js';

// You'll need to export your Fastify app from index.ts
// For now, this is the structure:

describe('Player API Tests', () => {
  let request: any;
  let db: any;

  beforeEach(() => {
    db = getDatabase();
    db.deleteAll(); // Clean slate before each test
  });

  describe('Creating a user by specifying its alias', () => {
    it('should create the user inside the database', async () => {
      const res = await request.post('/api/players')
        .send({ playerName: 'TestPlayer' })
        .expect(201);

      expect(res.body).toHaveProperty('newPlayerId');
      expect(res.body.playerName).toBe('TestPlayer');

      // Verify in DB
      const player = db.getPlayer('TestPlayer');
      expect(player).toBeDefined();
      expect(player.alias).toBe('TestPlayer');
    });

    it('should reject invalid names (< 3 chars)', async () => {
      await request.post('/api/players')
        .send({ playerName: 'AB' })
        .expect(500);
    });

    it('should reject names with invalid characters', async () => {
      await request.post('/api/players')
        .send({ playerName: 'Test@Player!' })
        .expect(500);
    });
  });

  describe('Trying to connect as the same user but with a different cookie', () => {
    it('should refuse the connection and NOT create another user with the same alias', async () => {
      // First user creates account
      const res1 = await request.post('/api/players')
        .send({ playerName: 'Bob' })
        .expect(201);

      const cookie1 = res1.headers['set-cookie'];

      // Second request, NO cookie (different session)
      const res2 = await request.post('/api/players')
        .send({ playerName: 'Bob' })
        .expect(409); // Conflict

      expect(res2.body.error).toContain('déjà pris');

      // Verify only ONE Bob in DB
      const players = db.getAllPlayers();
      const bobs = players.filter((p: any) => p.alias === 'Bob');
      expect(bobs).toHaveLength(1);
    });
  });
});

describe('Tournament API Tests', () => {
  let request: any;
  let db: any;
  let playerCookie: string;

  beforeEach(async () => {
    db = getDatabase();
    db.deleteAll();

    // Create a player for tests
    const res = await request.post('/api/players')
      .send({ playerName: 'TestCreator' });
    playerCookie = res.headers['set-cookie'];
  });

  describe('Creating a tournament that doesnt exist', () => {
    it('should create a tournament', async () => {
      const res = await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'TestTournament',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(201);

      expect(res.body.success).toBe(true);
      expect(res.body.name).toBe('TestTournament');

      // Verify in DB
      const tournament = db.getTournament(undefined, 'TestTournament');
      expect(tournament).toBeDefined();
    });
  });

  describe('Creating a wrong tournament', () => {
    it('should reject odd number of players', async () => {
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'BadTournament',
          maxPlayers: 3, // ❌ Odd
          creatorName: 'TestCreator'
        })
        .expect(404); // Your current error code
    });

    it('should reject maxPlayers < 2', async () => {
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'BadTournament',
          maxPlayers: 1,
          creatorName: 'TestCreator'
        })
        .expect(404);
    });

    it('should reject maxPlayers > 64', async () => {
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'BadTournament',
          maxPlayers: 100,
          creatorName: 'TestCreator'
        })
        .expect(404);
    });

    it('should reject invalid tournament name (< 3 chars)', async () => {
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'AB',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(404);
    });

    it('should reject tournament name with invalid characters', async () => {
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'Test@Tournament!',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(404);
    });

    it('should reject duplicate tournament name', async () => {
      // Create first tournament
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'DuplicateTest',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(201);

      // Try to create another with same name
      const res2 = await request.post('/api/players')
        .send({ playerName: 'SecondCreator' });
      
      await request.post('/api/tournaments')
        .set('Cookie', res2.headers['set-cookie'])
        .send({
          name: 'DuplicateTest',
          maxPlayers: 4,
          creatorName: 'SecondCreator'
        })
        .expect(500);
    });

    it('should reject if creator is already in another tournament', async () => {
      // Create first tournament
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'Tournament1',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(201);

      // Try to create second tournament
      await request.post('/api/tournaments')
        .set('Cookie', playerCookie)
        .send({
          name: 'Tournament2',
          maxPlayers: 4,
          creatorName: 'TestCreator'
        })
        .expect(409);
    });
  });

  describe('Trying to join multiple tournaments', () => {
    it('should block entrance into another tournament', async () => {
      // Create two tournaments
      const creator1 = await request.post('/api/players')
        .send({ playerName: 'Creator1' });
      
      await request.post('/api/tournaments')
        .set('Cookie', creator1.headers['set-cookie'])
        .send({
          name: 'Tournament1',
          maxPlayers: 4,
          creatorName: 'Creator1'
        });

      const creator2 = await request.post('/api/players')
        .send({ playerName: 'Creator2' });
      
      const res = await request.post('/api/tournaments')
        .set('Cookie', creator2.headers['set-cookie'])
        .send({
          name: 'Tournament2',
          maxPlayers: 4,
          creatorName: 'Creator2'
        });

      const t1Id = (await request.get('/api/tournaments')).body.tournaments[0].id;
      const t2Id = res.body.id;

      // Player joins Tournament1
      const joiner = await request.post('/api/players')
        .send({ playerName: 'Joiner' });

      await request.post(`/api/tournaments/${t1Id}/join`)
        .set('Cookie', joiner.headers['set-cookie'])
        .send({ playerName: 'Joiner' })
        .expect(200);

      // Try to join Tournament2
      await request.post(`/api/tournaments/${t2Id}/join`)
        .set('Cookie', joiner.headers['set-cookie'])
        .send({ playerName: 'Joiner' })
        .expect(409);

      // Verify player only in Tournament1
      const players = db.getTournamentPlayers(t1Id);
      expect(players.some((p: any) => p.alias === 'Joiner')).toBe(true);

      const players2 = db.getTournamentPlayers(t2Id);
      expect(players2.some((p: any) => p.alias === 'Joiner')).toBe(false);
    });
  });
});
````

## Additional Tests to Add

````typescript
describe('Edge Cases & Security', () => {
  it('should handle concurrent join requests (race condition)', async () => {
    // Create tournament
    const creator = await request.post('/api/players')
      .send({ playerName: 'Creator' });
    
    const res = await request.post('/api/tournaments')
      .set('Cookie', creator.headers['set-cookie'])
      .send({
        name: 'RaceTest',
        maxPlayers: 2, // Only 1 spot left
        creatorName: 'Creator'
      });

    const tournamentId = res.body.id;

    // Two players try to join simultaneously
    const player1 = await request.post('/api/players')
      .send({ playerName: 'Racer1' });
    
    const player2 = await request.post('/api/players')
      .send({ playerName: 'Racer2' });

    const [res1, res2] = await Promise.all([
      request.post(`/api/tournaments/${tournamentId}/join`)
        .set('Cookie', player1.headers['set-cookie'])
        .send({ playerName: 'Racer1' }),
      request.post(`/api/tournaments/${tournamentId}/join`)
        .set('Cookie', player2.headers['set-cookie'])
        .send({ playerName: 'Racer2' })
    ]);

    // One should succeed, one should fail
    const statuses = [res1.status, res2.status].sort();
    expect(statuses).toEqual([200, 500]); // One success, one error

    // Verify only 2 players in tournament
    const tournament = db.getTournament(tournamentId);
    expect(tournament.curr_nb_players).toBe(2);
  });

  it('should prevent unauthenticated access to /api/players/me', async () => {
    await request.get('/api/players/me')
      .expect(401);
  });

  it('should handle SQL injection attempts', async () => {
    await request.post('/api/players')
      .send({ playerName: "'; DROP TABLE players; --" })
      .expect(500); // Should fail validation
  });

  it('should cleanup tournament when last player leaves', async () => {
    const creator = await request.post('/api/players')
      .send({ playerName: 'SoloCreator' });
    
    const res = await request.post('/api/tournaments')
      .set('Cookie', creator.headers['set-cookie'])
      .send({
        name: 'EmptyTournament',
        maxPlayers: 4,
        creatorName: 'SoloCreator'
      });

    const tournamentId = res.body.id;

    // Creator leaves
    await request.post(`/api/tournaments/${tournamentId}/leave`)
      .set('Cookie', creator.headers['set-cookie'])
      .send({ playerName: 'SoloCreator' })
      .expect(200);

    // Tournament should be deleted
    const tournament = db.getTournament(tournamentId);
    expect(tournament).toBeUndefined();
  });
});
````

## Run Tests

Add to package.json:

```json
{
  "scripts": {
    "test": "vitest",
    "test:ui": "vitest --ui"
  }
}
```

Run:
```bash
npm test
```

**Benefits over a custom script:**
- ✅ Standard tooling
- ✅ Watch mode (re-runs on code changes)
- ✅ Clear pass/fail output
- ✅ Easy to integrate with CI/CD
- ✅ UI for debugging (`vitest --ui`)